          </thead>
          <tbody className="divide-y">
            {loading ? (
              <tr><td colSpan={5} className="text-center py-12">Đang tải...</td></tr>
            ) : branches.length === 0 ? (
              <tr><td colSpan={5} className="text-center py-12 text-gray-400">Chưa có chi nhánh nào</td></tr>
